{
  "extends": [
    "./tsconfig.app.json",
    "./tsconfig.node.json"
  ],
  "compilerOptions": {
    "types": [
      "vitest",
      "vitest/globals",
      "node",
      "dom"
    ],
    "module": "ESNext",
    "target": "ESNext",
    "isolatedModules": true,
    "composite": true,
    "noEmit": true,
    "lib": [
      "dom"
    ]
  },
  "include": [
    "src",
    "tests",
    "e2e",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "setupTests.ts",
    "playwright.config.ts"
  ]
}
